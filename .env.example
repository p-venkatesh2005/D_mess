# Dwaraka Mess Management System - Environment Variables

# FLASK_APP is the entrypoint for your application
FLASK_APP=app.py

# FLASK_ENV can be 'development' or 'production'
# Use 'production' when deploying to a live server
FLASK_ENV=production

# SECRET_KEY is used for securely signing the session cookie
# IMPORTANT: Generate a strong, random key for production
# You can generate one using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-production-key-here

# DATABASE_URL is the connection string to your database
# For SQLite (default): sqlite:///dwaraka_mess.db
# For PostgreSQL: postgresql://username:password@localhost/dbname
DATABASE_URL=sqlite:///dwaraka_mess.db

# Optional configuration overrides
# UPLOAD_FOLDER=static/uploads/payments
# MAX_CONTENT_LENGTH=5242880
